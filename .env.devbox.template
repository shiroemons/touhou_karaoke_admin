# devbox環境用の環境変数テンプレート
# cp .env.devbox.template .env で使用

# Algolia Configuration (Required)
ALGOLIA_APPLICATION_ID=your_application_id
ALGOLIA_API_KEY=your_api_key
ALGOLIA_INDEX_NAME=touhou_karaoke

# Admin Basic Auth (Optional)
# 両方を設定した場合のみ /admin 配下で Basic 認証を有効化
# TOUHOU_KARAOKE_ADMIN_BASIC_AUTH_USERNAME=admin
# TOUHOU_KARAOKE_ADMIN_BASIC_AUTH_PASSWORD=change_me

# PostgreSQL (devbox.jsonで自動設定されるため通常変更不要)
# PGHOST=/tmp
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
