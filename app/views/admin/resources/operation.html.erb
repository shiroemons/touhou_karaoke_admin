<header class="admin-page-header">
  <div>
    <h1><%= @operation.label %></h1>
    <p><%= @resource.label %></p>
  </div>
  <div class="admin-header-actions">
    <% if @record.present? %>
      <%= link_to admin_resource_path(@resource, @record), class: "admin-button btn" do %>
        <%= admin_icon(:back) %>
        <span>詳細へ戻る</span>
      <% end %>
    <% else %>
      <%= link_to admin_resources_path(@resource), class: "admin-button btn" do %>
        <%= admin_icon(:back) %>
        <span>一覧へ戻る</span>
      <% end %>
    <% end %>
  </div>
</header>

<section class="admin-panel">
  <h2>説明</h2>
  <div class="admin-operation-description"><%= linked_operation_description(@operation.description) %></div>
</section>

<section class="admin-panel">
  <h2>実行</h2>
  <%= render "operation_form", resource: @resource, record: @record, operation: @operation %>
</section>

<dialog class="modal" data-admin-operation-dialog data-admin-operation-confirm-dialog>
  <div class="modal-box">
    <h3 class="font-bold text-lg">アクションを実行しますか？</h3>
    <p class="py-4" data-admin-operation-dialog-message></p>
    <div class="modal-action">
      <button type="button" class="btn" data-admin-operation-cancel>キャンセル</button>
      <button type="button" class="btn btn-primary" data-admin-operation-confirm>実行</button>
    </div>
  </div>
</dialog>
