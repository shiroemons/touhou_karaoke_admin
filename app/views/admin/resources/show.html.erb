<header class="admin-detail-hero">
  <div class="admin-detail-title">
    <span class="admin-detail-resource"><%= @resource.label %></span>
    <h1><%= admin_record_title(@resource, @record) %></h1>
    <p class="admin-detail-identity">
      <span>ID</span>
      <code><%= admin_record_identifier(@record) %></code>
    </p>
  </div>
  <div class="admin-header-actions">
    <%= link_to admin_resources_path(@resource), class: "admin-button btn" do %>
      <%= admin_icon(:back) %>
      <span>一覧へ戻る</span>
    <% end %>
    <% if policy(@record).update? %>
      <%= link_to edit_admin_resource_path(@resource, @record), class: "admin-button admin-button-primary btn btn-primary" do %>
        <%= admin_icon(:edit) %>
        <span>編集</span>
      <% end %>
    <% end %>
    <% if policy(@record).destroy? %>
      <%= button_to admin_resource_path(@resource, @record), method: :delete, form: { data: { turbo_confirm: "削除しますか？" } }, class: "admin-button admin-button-danger btn btn-error" do %>
        <%= admin_icon(:delete) %>
        <span>削除</span>
      <% end %>
    <% end %>
  </div>
</header>

<%= render "operations", resource: @resource, record: @record %>

<section class="admin-detail-section" aria-labelledby="admin-detail-fields-heading">
  <div class="admin-section-heading">
    <h2 id="admin-detail-fields-heading">基本情報</h2>
    <p><%= @resource.show_fields.size %> 項目</p>
  </div>
  <dl class="admin-detail-grid">
    <% @resource.show_fields.each do |field| %>
      <div class="admin-detail-row">
        <dt><%= field.label %></dt>
        <dd class="<%= admin_field_value_class(@record, field) %>"><%= admin_field_value(@record, field) %></dd>
      </div>
    <% end %>
  </dl>
</section>

<% if @change_logs.present? %>
  <section class="admin-detail-section" aria-labelledby="admin-detail-change-logs-heading">
    <div class="admin-section-heading">
      <h2 id="admin-detail-change-logs-heading">変更履歴</h2>
      <p>管理画面で記録された作成・更新</p>
    </div>
    <ol class="admin-change-log-list">
      <% @change_logs.each do |change_log| %>
        <li class="admin-change-log-item">
          <header class="admin-change-log-header">
            <span class="<%= ["admin-change-event", admin_change_log_event_class(change_log)].compact.join(" ") %>">
              <%= admin_change_log_event_label(change_log) %>
            </span>
            <time datetime="<%= change_log.created_at.iso8601 %>">
              <%= l(change_log.created_at.in_time_zone("Asia/Tokyo"), format: :admin_datetime) %>
            </time>
            <span><%= change_log.actor_name %></span>
          </header>
          <% if change_log.changed_fields.present? %>
            <dl class="admin-change-fields">
              <% change_log.changed_fields.each_value do |change| %>
                <div class="admin-change-field">
                  <dt><%= change["label"] %></dt>
                  <dd>
                    <span><%= admin_change_log_value(change["before"]) %></span>
                    <%= admin_icon(:next) %>
                    <span><%= admin_change_log_value(change["after"]) %></span>
                  </dd>
                </div>
              <% end %>
            </dl>
          <% else %>
            <p class="admin-empty-state">フィールド差分はありません。</p>
          <% end %>
        </li>
      <% end %>
    </ol>
  </section>
<% end %>

<% if @resource.associations.present? %>
  <section class="admin-detail-section" aria-labelledby="admin-detail-associations-heading">
    <div class="admin-section-heading">
      <h2 id="admin-detail-associations-heading">関連データ</h2>
      <p>全件表示</p>
    </div>
    <div class="admin-related-sections">
      <% @resource.associations.each do |association| %>
        <% records = admin_association_records(@record, association) %>
        <% count = admin_association_count(@record, association) %>
        <section class="admin-related-section">
          <header>
            <div>
              <h3><%= admin_association_label(association) %></h3>
              <span><%= number_with_delimiter(count) %> 件</span>
            </div>
            <% if @resource.key == :display_artist && association == :circles && policy(@record).update? %>
              <button type="button" class="admin-button btn btn-sm" data-admin-association-dialog-trigger="display-artist-circles">
                <%= admin_icon(:edit) %>
                <span>紐づけ</span>
              </button>
            <% end %>
          </header>
          <% if records.present? %>
            <ul class="admin-related-list">
              <% records.each do |related_record| %>
                <% related_resource = admin_related_resource(related_record) %>
                <li>
                  <% if related_resource %>
                    <%= link_to admin_record_title(related_resource, related_record), admin_resource_path(related_resource, related_record) %>
                  <% else %>
                    <span><%= related_record.to_s %></span>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="admin-empty-state">関連データはありません。</p>
          <% end %>
        </section>
      <% end %>
    </div>
  </section>
<% end %>

<% if @resource.key == :display_artist && policy(@record).update? %>
  <% circle_field = @resource.fields.find { |field| field.name == :circle_ids } %>
  <% if circle_field %>
    <dialog class="modal admin-association-dialog" data-admin-association-dialog="display-artist-circles">
      <div class="modal-box admin-association-dialog-box">
        <div class="admin-operation-modal-header">
          <div>
            <span class="admin-operation-modal-resource">関連データ</span>
            <h2>サークルを紐づけ</h2>
          </div>
          <button type="button" class="btn btn-sm btn-circle btn-ghost" aria-label="閉じる" data-admin-association-dialog-close><%= admin_icon(:clear) %></button>
        </div>

        <%= form_with model: [:admin, @record], url: admin_resource_path(@resource, @record), method: :patch, class: "admin-form admin-association-dialog-form" do |form| %>
          <div class="admin-form-row">
            <%= form.label circle_field.name, circle_field.label %>
            <%= admin_field_input(form, circle_field) %>
          </div>
          <div class="admin-form-actions">
            <%= button_tag type: :submit, class: "admin-button admin-button-primary btn btn-primary" do %>
              <%= admin_icon(:edit) %>
              <span>更新</span>
            <% end %>
            <button type="button" class="admin-button btn" data-admin-association-dialog-close>
              <%= admin_icon(:clear) %>
              <span>キャンセル</span>
            </button>
          </div>
        <% end %>
      </div>
      <form method="dialog" class="modal-backdrop">
        <button type="submit">閉じる</button>
      </form>
    </dialog>
  <% end %>
<% end %>
