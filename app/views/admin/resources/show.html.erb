<header class="admin-detail-hero">
  <div class="admin-detail-title">
    <span class="admin-detail-resource"><%= @resource.label %></span>
    <h1><%= admin_record_title(@resource, @record) %></h1>
    <p class="admin-detail-identity">
      <span>ID</span>
      <code><%= admin_record_identifier(@record) %></code>
    </p>
  </div>
  <div class="admin-header-actions">
    <%= link_to admin_resources_path(@resource), class: "admin-button btn" do %>
      <%= admin_icon(:back) %>
      <span>一覧へ戻る</span>
    <% end %>
    <% if policy(@record).update? %>
      <%= link_to edit_admin_resource_path(@resource, @record), class: "admin-button admin-button-primary btn btn-primary" do %>
        <%= admin_icon(:edit) %>
        <span>編集</span>
      <% end %>
    <% end %>
    <% if policy(@record).destroy? %>
      <%= button_to admin_resource_path(@resource, @record), method: :delete, form: { data: { turbo_confirm: "削除しますか？" } }, class: "admin-button admin-button-danger btn btn-error" do %>
        <%= admin_icon(:delete) %>
        <span>削除</span>
      <% end %>
    <% end %>
  </div>
</header>

<%= render "operations", resource: @resource, record: @record %>

<section class="admin-detail-section" aria-labelledby="admin-detail-fields-heading">
  <div class="admin-section-heading">
    <h2 id="admin-detail-fields-heading">基本情報</h2>
    <p><%= @resource.show_fields.size %> 項目</p>
  </div>
  <dl class="admin-detail-grid">
    <% @resource.show_fields.each do |field| %>
      <div class="admin-detail-row">
        <dt><%= field.label %></dt>
        <dd class="<%= admin_field_value_class(@record, field) %>"><%= admin_field_value(@record, field) %></dd>
      </div>
    <% end %>
  </dl>
</section>

<% if @resource.associations.present? %>
  <section class="admin-detail-section" aria-labelledby="admin-detail-associations-heading">
    <div class="admin-section-heading">
      <h2 id="admin-detail-associations-heading">関連データ</h2>
      <p>全件表示</p>
    </div>
    <div class="admin-related-sections">
      <% @resource.associations.each do |association| %>
        <% records = admin_association_records(@record, association) %>
        <% count = admin_association_count(@record, association) %>
        <section class="admin-related-section">
          <header>
            <h3><%= admin_association_label(association) %></h3>
            <span><%= number_with_delimiter(count) %> 件</span>
          </header>
          <% if records.present? %>
            <ul class="admin-related-list">
              <% records.each do |related_record| %>
                <% related_resource = admin_related_resource(related_record) %>
                <li>
                  <% if related_resource %>
                    <%= link_to admin_record_title(related_resource, related_record), admin_resource_path(related_resource, related_record) %>
                  <% else %>
                    <span><%= related_record.to_s %></span>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="admin-empty-state">関連データはありません。</p>
          <% end %>
        </section>
      <% end %>
    </div>
  </section>
<% end %>
